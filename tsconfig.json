{
  "include": [
    "src/**/*",
    "tests/**/*",
    "scripts/**/*",
    "youtube-auto-play/src/**/*",
    "youtube-auto-play/vite.config.ts",
    ".react-router/types/**/*"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "youtube-auto-play/dist",
    "test-results",
    "logs",
    "tmp_test_data"
  ],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2023"],
    "types": ["vite/client", "bun"],
    "target": "ES2023",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "~/*": ["./src/app/*"],
      "@/*": ["./src/*"],
      "@shadcn/ui/*": ["./src/app/components/ui/shadcn/*"],
      "@conform-to/zod": ["./node_modules/@conform-to/zod/dist/v3"]
    },
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true
  }
}
