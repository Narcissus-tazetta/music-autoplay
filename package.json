{
  "name": "music-auto-play",
  "private": true,
  "type": "module",
  "scripts": {
    "actions": "bun run tsc && bun run lint && bun test",
    "build": "node node_modules/@react-router/dev/bin.cjs build",
    "build:extension": "vite build --config youtube-auto-play/vite.config.ts && node youtube-auto-play/scripts/copy-manifest.js",
    "dev": "tsx watch src/server/server.ts",
    "lint": "oxlint --fix && dprint fmt",
    "prepare": "husky",
    "start": "cross-env NODE_ENV=production tsx src/server/server.ts",
    "test:critical": "bun test tests/critical",
    "test:unit": "bun test tests/unit",
    "tsc": "tsc --noEmit",
    "update": "bunx npm-check-updates -u && bun install"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,css,md,json}": [
      "dprint fmt"
    ],
    "*.{ts,tsx,js,jsx}": [
      "oxlint --fix"
    ],
    "package.json": [
      "sort-package-json"
    ]
  },
  "dependencies": {
    "@conform-to/dom": "^1.19.4",
    "@conform-to/zod": "^1.19.4",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-hover-card": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-toggle": "^1.1.12",
    "@radix-ui/react-toggle-group": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@react-router/express": "^8.0.1",
    "@react-router/node": "^8.0.1",
    "chalk": "^5.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cross-env": "^10.1.0",
    "dompurify": "^3.4.11",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "googleapis": "^173.0.0",
    "helmet": "^8.2.0",
    "isbot": "^5.1.43",
    "jose": "^6.2.3",
    "lucide-react": "^1.21.0",
    "mongodb": "^7.3.0",
    "mongoose": "^9.7.1",
    "morgan": "^1.11.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-router": "^8.0.1",
    "socket.io": "^4.8.3",
    "strip-ansi": "^7.2.0",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.4",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@conform-to/react": "^1.19.4",
    "@react-router/dev": "^8.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/bun": "^1.3.14",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.3",
    "@types/morgan": "^1.9.10",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "convert-iso8601-duration": "^3.0.0",
    "crx3": "^2.0.0",
    "dprint": "^0.54.0",
    "framer-motion": "^12.40.0",
    "git-cliff": "^2.13.1",
    "husky": "^9.1.7",
    "immer": "^11.1.8",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.17.1",
    "lint-staged": "^17.0.7",
    "mongodb-memory-server": "^11.2.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "remix-auth": "^4.2.0",
    "remix-auth-oauth2": "^3.4.1",
    "remix-themes": "^2.0.4",
    "socket.io-client": "^4.8.3",
    "sort-package-json": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "zustand": "^5.0.14"
  }
}
